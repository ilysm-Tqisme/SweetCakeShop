@model SweetCakeShop.Models.ViewModels.AdminCouponViewModel

@{
    ViewData["Title"] = "Tạo mã giảm giá";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Tạo mã giảm giá mới</h2>
    <a asp-action="Coupons" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="CreateCoupon" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label fw-bold">Mã (CODE) *</label>
                            <input asp-for="Code" class="form-control text-uppercase" placeholder="Ví dụ: SUMMER2026" required />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <input asp-for="Description" class="form-control" placeholder="Mô tả ngắn gọn" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="DiscountType" class="form-label fw-bold">Loại giảm giá</label>
                            <select asp-for="DiscountType" class="form-select" id="discountTypeSelect">
                                <option value="Percentage">Phần trăm (%)</option>
                                <option value="FixedAmount">Số tiền cố định (VNĐ)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DiscountValue" class="form-label fw-bold">Giá trị giảm</label>
                            <input asp-for="DiscountValue" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="DiscountValue" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="MinOrderAmount" class="form-label fw-bold">Đơn hàng tối thiểu (VNĐ)</label>
                            <input asp-for="MinOrderAmount" type="number" class="form-control" value="0" />
                            <span asp-validation-for="MinOrderAmount" class="text-danger"></span>
                        </div>
                        <div class="col-md-6" id="maxDiscountContainer">
                            <label asp-for="MaxDiscountAmount" class="form-label fw-bold">Giảm tối đa (VNĐ)</label>
                            <input asp-for="MaxDiscountAmount" type="number" class="form-control" value="0" />
                            <small class="text-muted">Nhập 0 nếu không giới hạn</small>
                            <span asp-validation-for="MaxDiscountAmount" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="ValidFrom" class="form-label fw-bold">Từ ngày</label>
                            <input asp-for="ValidFrom" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="ValidFrom" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ValidTo" class="form-label fw-bold">Đến ngày</label>
                            <input asp-for="ValidTo" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="ValidTo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="MaxUsageCount" class="form-label fw-bold">Tổng lượt dùng tối đa</label>
                            <input asp-for="MaxUsageCount" type="number" class="form-control" value="0" />
                            <small class="text-muted">Nhập 0 để không giới hạn</small>
                            <span asp-validation-for="MaxUsageCount" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxUsagePerUser" class="form-label fw-bold">Số lượt/Khách hàng</label>
                            <input asp-for="MaxUsagePerUser" type="number" class="form-control" value="1" min="1" />
                            <span asp-validation-for="MaxUsagePerUser" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch" checked>
                        <label class="form-check-label fw-bold" for="isActiveSwitch">Kích hoạt mã</label>
                    </div>

                    <button type="submit" class="btn btn-primary px-4 py-2">Thêm mã giảm giá</button>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card bg-light border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Hướng dẫn</h5>
                <p class="small text-muted mb-2"><strong>Mã (CODE):</strong> Viết liền không dấu, nên sử dụng chữ in hoa (VD: FREESHIP, GIAIMNHIET).</p>
                <p class="small text-muted mb-2"><strong>Loại giảm giá:</strong> Nếu chọn "Phần trăm", hãy nhập số từ 1-100 vào ô Giá trị giảm. Nếu chọn "Số tiền cố định", hãy nhập số tiền VND (VD: 50000).</p>
                <p class="small text-muted mb-2"><strong>Giảm tối đa:</strong> Chỉ áp dụng khi loại giảm giá là "Phần trăm".</p>
                <p class="small text-muted mb-0"><strong>Số lượt/Khách hàng:</strong> Mỗi khách hàng (đăng nhập) chỉ được dùng tối đa bao nhiêu lần mã này.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var typeSelect = document.getElementById('discountTypeSelect');
            var maxDiscountContainer = document.getElementById('maxDiscountContainer');
            
            function toggleMaxDiscount() {
                if(typeSelect.value === 'FixedAmount') {
                    maxDiscountContainer.style.display = 'none';
                    document.getElementById('MaxDiscountAmount').value = '0';
                } else {
                    maxDiscountContainer.style.display = 'block';
                }
            }
            
            typeSelect.addEventListener('change', toggleMaxDiscount);
            toggleMaxDiscount();
        });
    </script>
}
