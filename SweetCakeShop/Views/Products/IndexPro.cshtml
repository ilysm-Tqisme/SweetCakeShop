@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<SweetCakeShop.Models.Product>

@{
    ViewData["Title"] = "Tất cả sản phẩm";
    var currentSort = ViewData["CurrentSort"] as string;
    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentCategoryId = ViewData["CurrentCategoryId"] is int categoryId ? categoryId : (int?)null;
    var currentCategoryName = ViewData["CurrentCategoryName"] as string;
    var minPrice = ViewData["MinPrice"]?.ToString();
    var maxPrice = ViewData["MaxPrice"]?.ToString();
    var minRating = ViewData["MinRating"]?.ToString();
}

<div class="container-fluid px-lg-5 mt-4">

    <div class="row">
        <!-- Lọc Nâng Cao Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 rounded-4 sticky-top" style="top: 20px; background-color: #fffafc;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-pink"><i class="bi bi-funnel-fill me-2"></i>Bộ Lọc Tìm Kiếm</h5>
                    <form method="get" id="filterForm">
                        <input type="hidden" name="searchTerm" value="@currentSearch" />
                        <input type="hidden" name="categoryId" value="@currentCategoryId" />
                        <input type="hidden" name="categoryName" value="@currentCategoryName" />
                        <input type="hidden" name="sortOrder" id="hiddenSortOrder" value="@currentSort" />

                        <!-- Price Range -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-dark">Khoảng giá (VND)</label>
                            <div class="input-group mb-2 shadow-sm rounded-pill overflow-hidden">
                                <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-cash"></i></span>
                                <input type="number" class="form-control border-0" name="minPrice" placeholder="Từ giá" value="@minPrice">
                            </div>
                            <div class="input-group shadow-sm rounded-pill overflow-hidden">
                                <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-cash"></i></span>
                                <input type="number" class="form-control border-0" name="maxPrice" placeholder="Đến giá" value="@maxPrice">
                            </div>
                        </div>

                        <!-- Rating Filter -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-dark">Đánh giá tối thiểu</label>
                            <select class="form-select shadow-sm rounded-pill border-0 py-2" name="minRating">
                                <option value="">Tất cả đánh giá</option>
                                <option value="5" selected="@(minRating == "5")">⭐⭐⭐⭐⭐ (5 sao)</option>
                                <option value="4" selected="@(minRating == "4")">⭐⭐⭐⭐ trở lên</option>
                                <option value="3" selected="@(minRating == "3")">⭐⭐⭐ trở lên</option>
                                <option value="2" selected="@(minRating == "2")">⭐⭐ trở lên</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-pink rounded-pill py-2 fw-bold shadow-sm">Áp dụng bộ lọc</button>
                            <a href="/Products/IndexPro" class="btn btn-light rounded-pill py-2 text-muted fw-bold border">Xóa bộ lọc</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Main Product Grid -->
        <div class="col-md-9">
            <!-- Header với tiêu đề và filter -->
            <div class="row align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm mx-1">
                <div class="col-md-6">
                    <h3 class="fw-bold mb-0 text-dark">
                        @if (!string.IsNullOrEmpty(currentSearch))
                        {
                            <span>Kết quả tìm kiếm: "@currentSearch"</span>
                        }
                        else if (!string.IsNullOrEmpty(currentCategoryName))
                        {
                            <span>@currentCategoryName</span>
                        }
                        else
                        {
                            <span>Tất cả sản phẩm</span>
                        }
                    </h3>
                </div>
                <div class="col-md-6 text-end">
                    <div class="d-inline-flex align-items-center">
                        <label class="me-2 text-muted fw-semibold mb-0">Sắp xếp:</label>
                        <select class="form-select form-select-sm rounded-pill border-0 bg-light shadow-sm py-2 px-3" style="width: 200px;" onchange="updateSort(this.value)">
                            <option value="" selected="@(string.IsNullOrEmpty(currentSort))">Mặc định</option>
                            <option value="price_asc" selected="@(currentSort == "price_asc")">Giá: Thấp đến Cao</option>
                            <option value="price_desc" selected="@(currentSort == "price_desc")">Giá: Cao đến Thấp</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Grid sản phẩm -->
            <div class="row g-4">
                @foreach (var product in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 col-6">
                        <a class="text-decoration-none text-dark" asp-action="Details" asp-route-id="@product.ProductId">
                            <div class="card h-100 shadow-sm border-0 product-card rounded-4 overflow-hidden">
                                
                                <!-- Hình ảnh sản phẩm -->
                                <div class="product-image-wrapper position-relative" style="height: 220px; overflow: hidden; background-color: #f8f9fa;">
                                    @if (!string.IsNullOrEmpty(product.Image))
                                    {
                                        <img src="@product.Image" class="card-img-top w-100 h-100 object-fit-cover transition-transform" alt="@product.ProductName">
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                                        </div>
                                    }
                                    <!-- Overlay for Add to Cart -->
                                    <div class="product-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(255,105,180,0.2); opacity: 0; transition: opacity 0.3s ease;">
                                        <button type="button" class="btn btn-pink rounded-pill px-4 shadow-lg scale-up" onclick="addToCart(event, @product.ProductId)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart-plus me-2" viewBox="0 0 16 16">
                                                <path d="M9 5.5a.5.5 0 0 0-1 0V7H6.5a.5.5 0 0 0 0 1H8v1.5a.5.5 0 0 0 1 0V8h1.5a.5.5 0 0 0 0-1H9z"/>
                                                <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                                            </svg>
                                            Thêm vào giỏ
                                        </button>
                                    </div>
                                </div>

                                <!-- Thông tin sản phẩm -->
                                <div class="card-body d-flex flex-column text-center p-3">
                                    <h6 class="card-title text-truncate mb-2 fw-bold text-dark">@product.ProductName</h6>
                                    
                                    <!-- Rating placeholder for UI consistency -->
                                    <div class="mb-2">
                                        <small class="text-warning">★★★★★</small>
                                    </div>

                                    <div class="mt-auto">
                                        <span class="text-pink fw-bold fs-5">@product.Price.ToString("N0")₫</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Pagination -->
            <div class="d-flex justify-content-center mt-5 pagination-custom">
                @Html.PagedListPager(
                    Model,
                    page => Url.Action("IndexPro", new { page, sortOrder = currentSort, searchTerm = currentSearch, categoryId = currentCategoryId, categoryName = currentCategoryName, minPrice, maxPrice, minRating }),
                    new PagedListRenderOptions
                    {
                        LiElementClasses = new[] { "page-item" },
                        PageClasses = new[] { "page-link shadow-sm" },
                        ActiveLiElementClass = "active"
                    })
            </div>

            @if (!Model.Any())
            {
                <div class="text-center mt-5 p-5 bg-white rounded-4 shadow-sm mx-auto" style="max-width: 500px;">
                    <img src="~/images/no-results.png" alt="No results" style="max-height: 150px; opacity: 0.5;" class="mb-4" onerror="this.style.display='none'">
                    <h4 class="text-muted fw-bold">Không tìm thấy sản phẩm nào</h4>
                    <p class="text-secondary">Vui lòng thử lại với bộ lọc hoặc từ khóa khác.</p>
                    <a href="/Products/IndexPro" class="btn btn-pink rounded-pill mt-3 px-4">Xóa bộ lọc</a>
                </div>
            }

        </div>
    </div>
</div>

<style>
    .text-pink { color: #ff69b4 !important; }
    
    .product-card {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(255, 105, 180, 0.15) !important;
    }
    .product-card img {
        transition: transform 0.5s ease;
    }
    .product-card:hover img {
        transform: scale(1.08);
    }
    .product-card:hover .product-overlay {
        opacity: 1 !important;
    }
    .scale-up {
        transform: scale(0.8);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .product-card:hover .scale-up {
        transform: scale(1);
    }
    
    .pagination-custom ul {
        display: flex;
        list-style: none;
        padding: 0;
        gap: 8px;
    }

    .pagination-custom .page-item {
        border-radius: 50%;
    }

    .pagination-custom .page-link {
        color: #ff69b4;
        border: none;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.3s ease;
        background: white;
        font-weight: 500;
    }

    .pagination-custom .page-link:hover {
        background: #ffeaf3;
        color: #ff1493;
    }

    .pagination-custom .active .page-link {
        background: #ff69b4;
        color: white;
        box-shadow: 0 4px 10px rgba(255, 105, 180, 0.3);
    }

    .pagination-custom .disabled .page-link {
        color: #ccc;
        pointer-events: none;
        background: #f8f9fa;
    }
    
    /* Bootstrap icon import if not present */
    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
</style>

<script>
    function updateSort(sortValue) {
        document.getElementById('hiddenSortOrder').value = sortValue;
        document.getElementById('filterForm').submit();
    }

    function addToCart(e, productId) {
        if (e && typeof e.stopPropagation === 'function') {
            e.preventDefault();
            e.stopPropagation();
        }
        addToCartAjax(productId, 1);
    }
</script>
