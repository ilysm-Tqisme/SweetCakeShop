@model SweetCakeShop.Models.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container my-5">
    <h2 class="text-center mb-4">Giỏ hàng của bạn</h2>

    @if (Model.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="list-group">
                    @Html.AntiForgeryToken()
                    @foreach (var item in Model.Items)
                    {
                        <div class="list-group-item p-3 mb-3 rounded shadow-sm cart-item" data-product-id="@item.ProductId">
                            <div class="row align-items-center g-2">
                                <div class="col-3 col-md-2">
                                    <img src="@item.Image" alt="@item.ProductName" class="img-fluid rounded" style="max-height:80px; object-fit:cover;" />
                                </div>
                                <div class="col-9 col-md-6">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                        <h6 class="mb-1 text-truncate">@item.ProductName</h6>
                                    </a>
                                    <div class="text-muted small">@item.Price.ToString("N0") ₫ / chiếc</div>
                                </div>

                                <div class="col-12 col-md-4 d-flex justify-content-between align-items-center mt-3 mt-md-0">
                                    <div class="input-group input-group-sm quantity-group" style="width:150px;">
                                        <button class="btn btn-outline-secondary btn-sm decrement" type="button" aria-label="Decrease">−</button>
                                        <input type="number" class="form-control text-center qty-input" value="@item.Quantity" min="1" data-product-id="@item.ProductId" />
                                        <button class="btn btn-outline-secondary btn-sm increment" type="button" aria-label="Increase">+</button>
                                    </div>

                                    <div class="text-end ms-3">
                                        <div class="fw-bold">@item.Subtotal.ToString("N0") ₫</div>
                                        <button class="btn btn-link text-danger p-0 mt-1 remove-btn" type="button" data-product-id="@item.ProductId">Xóa</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top:100px;">
                    <div class="card-body">
                        <h5 class="card-title">Tóm tắt đơn hàng</h5>

                        <div class="d-flex justify-content-between">
                            <div>Số mặt hàng</div>
                            <div class="fw-bold">@Model.Items.Sum(i => i.Quantity)</div>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <div>Tạm tính</div>
                            <div class="fw-bold">@Model.TotalAmount.ToString("N0") ₫</div>
                        </div>

                        <!-- Coupon Section -->
                        <hr />
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Mã giảm giá</label>
                            @if (!string.IsNullOrEmpty(Model.CouponCode))
                            {
                                <div class="alert alert-success d-flex justify-content-between align-items-center py-2 px-3 mb-2">
                                    <div>
                                        <i class="bi bi-tag-fill me-2"></i>
                                        <strong>@Model.CouponCode</strong>
                                    </div>
                                    <button class="btn btn-sm btn-link text-danger p-0" onclick="removeCoupon()">Xóa</button>
                                </div>
                                <div class="d-flex justify-content-between text-success">
                                    <div>Giảm giá</div>
                                    <div class="fw-bold">-@Model.DiscountAmount.ToString("N0") ₫</div>
                                </div>
                                <hr />
                                <div class="d-flex justify-content-between fs-5">
                                    <div class="fw-bold">Tổng cộng</div>
                                    <div class="fw-bold text-pink">@((Model.TotalAmount - Model.DiscountAmount).ToString("N0")) ₫</div>
                                </div>
                            }
                            else
                            {
                                <div class="input-group">
                                    <input id="coupon-code" class="form-control" placeholder="Nhập mã (nếu có)" />
                                    <button id="apply-coupon" class="btn btn-outline-pink" type="button">Áp dụng</button>
                                </div>
                                <div class="d-flex justify-content-between fs-5 mt-3">
                                    <div class="fw-bold">Tổng cộng</div>
                                    <div class="fw-bold text-pink">@Model.TotalAmount.ToString("N0") ₫</div>
                                </div>
                            }
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <a asp-controller="Cart" asp-action="Checkout" class="btn btn-pink btn-lg rounded-pill fw-bold shadow-sm">Tiến hành đặt hàng</a>
                            <a asp-controller="Products" asp-action="IndexPro" class="btn btn-outline-secondary rounded-pill">Tiếp tục mua sắm</a>
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-muted small px-2">
                    <p class="mb-1"><i class="bi bi-info-circle me-1"></i><strong>Ghi chú:</strong></p>
                    <p class="mb-0">Miễn phí giao hàng cho đơn hàng trên 500,000₫. Thông tin vận chuyển sẽ được yêu cầu ở bước thanh toán.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <img src="~/images/empty-cart.png" alt="Empty Cart" class="mb-4" style="max-height: 200px; opacity: 0.8;" onerror="this.style.display='none'" />
            <h4 class="text-muted mb-3">Giỏ hàng của bạn đang trống</h4>
            <a asp-controller="Products" asp-action="IndexPro" class="btn btn-pink rounded-pill px-4 py-2 fw-bold">Tiếp tục mua sắm</a>
        </div>
    }
</div>

<style>
    .btn-outline-pink {
        color: #ff69b4;
        border-color: #ff69b4;
    }
    .btn-outline-pink:hover {
        background-color: #ff69b4;
        color: white;
    }
    .text-pink { color: #ff69b4 !important; }
    .bg-pink { background-color: #ff69b4 !important; color: white !important; }
    .cart-item { transition: transform .2s ease, box-shadow .2s ease; border: 1px solid #f0f0f0; }
    .cart-item:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; }
    .quantity-group .btn { width: 38px; }
</style>

@section Scripts {
    <script>
        function getAntiForgeryToken() {
            const tokenField = document.querySelector('input[name="__RequestVerificationToken"]');
            return tokenField ? tokenField.value : '';
        }

        async function postForm(url, data) {
            const token = getAntiForgeryToken();
            if (token) data.__RequestVerificationToken = token;
            const body = new URLSearchParams();
            for (const k in data) body.append(k, data[k]);
            return await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            });
        }

        function debounce(func, wait) {
            let timeout;
            return (...args) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        async function updateQuantity(productId, quantity) {
            try {
                const res = await postForm('/Cart/Update', { productId: productId, quantity: quantity });
                if (res.ok) {
                    updateCartBadge();
                    location.reload();
                } else {
                    showToast('Không thể cập nhật số lượng.', 'danger');
                }
            } catch {
                showToast('Lỗi khi cập nhật số lượng.', 'danger');
            }
        }

        async function removeItem(productId) {
            if (!confirm('Bạn có chắc muốn xóa sản phẩm khỏi giỏ hàng?')) return;
            try {
                const res = await postForm('/Cart/Remove', { productId: productId });
                if (res.ok) {
                    updateCartBadge();
                    location.reload();
                } else {
                    showToast('Không thể xóa sản phẩm.', 'danger');
                }
            } catch {
                showToast('Lỗi khi xóa sản phẩm.', 'danger');
            }
        }

        async function removeCoupon() {
            try {
                const res = await postForm('/Cart/RemoveCoupon', {});
                if (res.ok) {
                    const data = await res.json();
                    if (data.success) {
                        location.reload();
                    }
                }
            } catch {
                showToast('Lỗi xóa mã.', 'danger');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.cart-item').forEach(function (el) {
                const productId = el.getAttribute('data-product-id');
                const decrement = el.querySelector('.decrement');
                const increment = el.querySelector('.increment');
                const qtyInput = el.querySelector('.qty-input');
                const debouncedUpdate = debounce(function (val) {
                    updateQuantity(productId, Math.max(1, parseInt(val || 1)));
                }, 500);

                decrement?.addEventListener('click', function () {
                    const val = Math.max(1, parseInt(qtyInput.value || '1') - 1);
                    qtyInput.value = val;
                    debouncedUpdate(val);
                });

                increment?.addEventListener('click', function () {
                    const val = Math.max(1, parseInt(qtyInput.value || '1') + 1);
                    qtyInput.value = val;
                    debouncedUpdate(val);
                });

                qtyInput?.addEventListener('input', function (e) {
                    const v = Math.max(1, parseInt(qtyInput.value || '1'));
                    qtyInput.value = v;
                    debouncedUpdate(v);
                });

                el.querySelector('.remove-btn')?.addEventListener('click', function () {
                    removeItem(productId);
                });
            });

            document.getElementById('apply-coupon')?.addEventListener('click', async function () {
                const code = document.getElementById('coupon-code')?.value?.trim();
                if (!code) {
                    showToast('Vui lòng nhập mã giảm giá.', 'warning');
                    return;
                }
                
                try {
                    const res = await postForm('/Cart/ApplyCoupon', { code: code });
                    const data = await res.json();
                    if (data.success) {
                        location.reload();
                    } else {
                        showToast(data.message || 'Mã giảm giá không hợp lệ', 'danger');
                    }
                } catch {
                    showToast('Lỗi áp dụng mã', 'danger');
                }
            });
        });
    </script>
}