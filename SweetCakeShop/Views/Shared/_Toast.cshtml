<div aria-live="polite" aria-atomic="true" class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    <div id="toast-container"></div>
</div>

<script>
    function showToast(message, type = 'info', delay = 3000) {
        // type: 'info', 'success', 'danger', 'warning'
        const toastId = 't' + Date.now() + Math.floor(Math.random() * 1000);
        const colorClass = {
            info: 'bg-info text-white',
            success: 'bg-success text-white',
            danger: 'bg-danger text-white',
            warning: 'bg-warning text-dark'
        }[type] || 'bg-info text-white';

        const wrapper = document.createElement('div');
        wrapper.innerHTML = `
            <div id="${toastId}" class="toast ${colorClass} align-items-center border-0 mb-2" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="${delay}">
                <div class="d-flex">
                    <div class="toast-body">
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>`;
        document.getElementById('toast-container')?.appendChild(wrapper);

        var toastEl = document.getElementById(toastId);
        var toast = new bootstrap.Toast(toastEl);
        toast.show();

        toastEl.addEventListener('hidden.bs.toast', function () {
            toastEl.remove();
        });
    }

    // Auto-show TempData messages
    document.addEventListener('DOMContentLoaded', () => {
        @if (TempData["Success"] != null)
        {
            <text>showToast('@Html.Raw(TempData["Success"]?.ToString()?.Replace("'", "\\'"))', 'success', 5000);</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>showToast('@Html.Raw(TempData["Error"]?.ToString()?.Replace("'", "\\'"))', 'danger', 5000);</text>
        }
        @if (TempData["Warning"] != null)
        {
            <text>showToast('@Html.Raw(TempData["Warning"]?.ToString()?.Replace("'", "\\'"))', 'warning', 5000);</text>
        }
        @if (TempData["Info"] != null)
        {
            <text>showToast('@Html.Raw(TempData["Info"]?.ToString()?.Replace("'", "\\'"))', 'info', 5000);</text>
        }

        // Fetch DB Notifications once after 2 seconds
        setTimeout(() => {
            fetch('/api/notifications/unread')
                .then(r => r.json())
                .then(data => {
                    if (data && data.length > 0) {
                        data.forEach(n => {
                            showToast(`<strong>${n.title}</strong><br/>${n.message}`, 'info', 7000);
                            // Mark as read after showing
                            fetch(`/api/notifications/mark-read/${n.notificationId}`, { method: 'POST' });
                        });
                    }
                }).catch(e => console.log('Notification fetch err:', e));
        }, 2000);
    });
</script>
