<button type="button" class="ai-chat-fab" id="customerChatFab" title="Tư vấn bánh SweetCakeShop">💬</button>

<div class="ai-chat-panel" id="customerChatPanel"
     data-product-id="@(ViewBag.ChatProductId as int?)">
    <div class="ai-chat-header d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold">SweetCakeShop</div>
            <small class="opacity-75">Tư vấn bánh & đặt hàng · Gemini AI</small>
        </div>
        <button type="button" class="btn-close btn-close-white btn-sm" id="customerChatClose"></button>
    </div>
    <div class="ai-chat-messages" id="customerChatMessages"></div>
    <div class="ai-chat-quick-replies" id="customerChatQuickReplies"></div>
    <div class="ai-chat-input-area">
        <input type="text" id="customerChatInput" class="form-control form-control-sm rounded-pill" maxlength="2000"
               placeholder="VD: Có bánh phô mai không?" autocomplete="off" />
        <button type="button" class="btn btn-scs-pink btn-sm rounded-pill px-3" id="customerChatSend">Gửi</button>
    </div>
</div>

<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
<script src="~/js/ai-chat.js" asp-append-version="true"></script>
<script>
    SweetCakeAiChat({
        fabId: 'customerChatFab',
        panelId: 'customerChatPanel',
        closeId: 'customerChatClose',
        inputId: 'customerChatInput',
        sendId: 'customerChatSend',
        messagesId: 'customerChatMessages',
        quickRepliesId: 'customerChatQuickReplies',
        historyUrl: '/api/Chat/GetChatHistory',
        sendUrl: '/api/Chat/SendMessage',
        suggestionsUrl: '/api/Chat/customer/suggestions',
        onCartAction: typeof updateCartBadge === 'function' ? updateCartBadge : null
    });
</script>
